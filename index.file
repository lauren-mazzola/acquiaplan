.sh{padding:32px 40px 24px;}
.sh.teal{background:linear-gradient(135deg,#0A4F6A,#0E6F8E);}
.sh.teal .sey,.sh.teal .stl,.sh.teal .sds{color:#fff;}
.sh.teal .sey{color:rgba(255,255,255,0.65);}
.sh.teal .sds{color:rgba(255,255,255,0.78);}
