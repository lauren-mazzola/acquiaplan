.av-c{background:#FDF0EC;color:#993C1D;}.av-g{background:#E6FAF2;color:#0A4A3A;}.av-m{background:#FAEEDA;color:#7A3F0A;}
.pn{font-size:13px;font-weight:600;color:#1a1a18;margin-bottom:2px;}
.pb{font-size:12px;color:#5f5e5a;line-height:1.5;}
.ar{display:flex;gap:10px;padding:8px 0;border-bottom:0.5px solid #e8e7e0;font-size:13px;line-height:1.5;align-items:flex-start;}
.ar:last-child{border-bottom:none;}
.xg{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:4px;}
