.dvd{height:1px;background:#e8e7e0;margin:20px 0;}
.stat-row{display:grid;grid-template-columns:repeat(4,1fr);gap:9px;margin-bottom:18px;}
.stat{background:#f5f5f3;border-radius:10px;padding:13px;text-align:center;}
.sv{font-size:22px;font-weight:700;color:#0E6F8E;}
.sl{font-size:11px;color:#5f5e5a;margin-top:3px;line-height:1.3;}
.tgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:9px;margin-bottom:20px;}
.tc{background:#f5f5f3;border-radius:10px;padding:13px;text-align:center;}
.ti{font-size:20px;margin-bottom:5px;}
.tl{font-size:11px;font-weight:600;color:#1a1a18;line-height:1.3;}
.as{background:#F0F9FB;border:1px solid #B8E4EE;border-radius:10px;padding:16px 18px;}
