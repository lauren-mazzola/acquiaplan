<style>
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Inter',sans-serif;background:#f5f5f3;color:#1a1a18;}
.bk{max-width:880px;margin:0 auto;padding:1rem 0 3rem;}
.nav{display:flex;gap:5px;flex-wrap:wrap;margin-bottom:1.5rem;padding:0 1rem;}
.nb{padding:6px 11px;border-radius:20px;border:0.5px solid #d0cfc8;font-size:11px;font-weight:500;cursor:pointer;background:transparent;color:#5f5e5a;transition:all .15s;font-family:inherit;}
.nb.active{background:#0E6F8E;color:#fff;border-color:transparent;}
